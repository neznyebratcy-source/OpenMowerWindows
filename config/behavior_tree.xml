<!--
  Coverage mowing behavior tree.

  ComputePathToPose calls the Nav2 planner server with planner_id="CoveragePlanner".
  Our plugin ignores the specific goal orientation and instead:
    1. Looks up all TYPE_OPERATION areas from the /map topic
    2. Picks the area nearest to the goal position
    3. Generates a full boustrophedon (snake) coverage path over that area
    4. Re-routes any strip segment that is blocked by an obstacle using A*
       on the global costmap (updated by the radar obstacle layer)

  To trigger mowing, send a NavigateToPose goal whose position falls inside
  (or near) the operation area you want to mow.  The planner will handle the rest.
-->

<root BTCPP_format="4" main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <RateController hz="0.0000001"> <!-- run once, for demo -->
            <Sequence name="CoverageSequence">
                <!-- Use our CoveragePlanner plugin for the global path -->
                <ComputePathToPose
                    goal="{goal}"
                    path="{path}"
                    planner_id="CoveragePlanner"
                    error_code_id="{compute_path_error_code}"/>
                <!-- Hand the coverage path to Regulated Pure Pursuit -->
                <FollowPath
                    path="{path}"
                    controller_id="FollowPath"
                    error_code_id="{follow_path_error_code}"/>
            </Sequence>
        </RateController>
    </BehaviorTree>
</root>