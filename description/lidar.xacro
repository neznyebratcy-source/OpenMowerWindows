<?xml version="1.0"?>
<!-- LIDAR ADDITION: This file defines the lidar sensor link, joint, and Gazebo simulation plugin.
     It follows the same pattern as imu.xacro and gps.xacro.
     Mount position is read from config/hardware/yardforce500.yaml under lidar.mount.offset -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="lidar">

    <!-- Fixed joint attaching the lidar to the robot base.
         Position is configured in yardforce500.yaml so it can be adjusted
         without touching this file. -->
    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="${robot['lidar']['mount']['offset'][0]} ${robot['lidar']['mount']['offset'][1]} ${robot['lidar']['mount']['offset'][2]}" rpy="0 0 0"/>
    </joint>

    <!-- Lidar link - no visual/collision geometry needed for a sensor-only link -->
    <link name="lidar_link">
    </link>

    <!-- Gazebo simulation sensor plugin for the lidar.
         Publishes sensor_msgs/LaserScan to /scan at 10 Hz.
         360-degree horizontal sweep, 0.1m - 10m range.
         The ros_gz_bridge in sim.launch.py bridges this topic into ROS2. -->
    <gazebo reference="lidar_link">
        <!-- gpu_lidar with ogre2 — works in Docker/WSL2 because docker-compose.yaml
             sets LIBGL_ALWAYS_SOFTWARE=1 to force Mesa software rendering -->
        <sensor name="lidar" type="gpu_lidar">
            <gz_frame_id>lidar_link</gz_frame_id>
            <always_on>1</always_on>
            <update_rate>10</update_rate>
            <topic>scan</topic>
            <visualize>true</visualize>
            <lidar>
                <scan>
                    <horizontal>
                        <!-- 360 samples = 1 degree resolution for a full 360 sweep -->
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.1</min>   <!-- minimum detection distance in meters -->
                    <max>10.0</max>  <!-- maximum detection distance in meters -->
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </lidar>
        </sensor>

        <material>Gazebo/Blue</material>
    </gazebo>

</robot>